---
import '../styles/global.css';
import '../styles/components.css';
import MetaPixel from '../components/MetaPixel.astro';
import SpeedInsights from '@vercel/speed-insights/astro';

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = 'Free Lunch & Learn for ambitious business owners ready to grow beyond their current operating level.',
} = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="preconnect" href="https://connect.facebook.net" />
    <link rel="dns-prefetch" href="https://connect.facebook.net" />
    <link rel="dns-prefetch" href="https://www.facebook.com" />
    <link rel="dns-prefetch" href="https://www.clarity.ms" />
    <link
      rel="preload"
      as="font"
      type="font/woff2"
      href="/fonts/open-sans-latin.woff2"
      crossorigin
    />
    <title>{title}</title>
    <slot name="head" />
    <MetaPixel />
    <script is:inline>
      (function(){
        var loaded = false;
        function loadClarity(){
          if (loaded) return; loaded = true;
          (function(c,l,a,r,i,t,y){
            c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
            t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;
            y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
          })(window, document, "clarity", "script", "wrmbsfmyay");
        }
        if (document.readyState === 'complete') setTimeout(loadClarity, 1500);
        else window.addEventListener('load', function(){ setTimeout(loadClarity, 1500); }, { once: true });
        var opts = { once: true, passive: true, capture: true };
        ['pointerdown','keydown','scroll','touchstart'].forEach(function(ev){
          window.addEventListener(ev, loadClarity, opts);
        });
      })();
    </script>
  </head>
  <body>
    <slot />
    <SpeedInsights />
  </body>
</html>
