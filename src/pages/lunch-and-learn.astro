---
import Base from '../layouts/Base.astro';
import Footer from '../components/Footer.astro';
import Nav from '../components/Nav.astro';
import RegisterPopup from '../components/RegisterPopup.astro';
import ReggieLandingPage from '../components/ReggieLandingPage.astro';
import { webinar } from '../config/webinar';
---
<Base
  title={webinar.title}
  description="Free Lunch & Learn for growth-minded business owners who are ready to stop being the bottleneck and grow the owner."
>
  <Fragment slot="head">
    <link rel="preload" as="image" href={webinar.heroCoachImage} />
    <link rel="preload" as="image" href={webinar.heroVideoPoster} />
  </Fragment>
  <Nav />
  <ReggieLandingPage />
  <Footer />
  <RegisterPopup />
</Base>
