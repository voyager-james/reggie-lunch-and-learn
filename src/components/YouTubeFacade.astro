---
import { Picture } from 'astro:assets';
import thumbnail from '../assets/images/reggie/youtube-wm9ym-L2i8Q.jpg';
import { webinar } from '../config/webinar';

interface Props {
  title?: string;
}

const { title = 'Play Why Business Owners Get Stuck and How to Break Through' } = Astro.props;
const embedSrc = `https://www.youtube-nocookie.com/embed/${webinar.youtubeId}?autoplay=1&rel=0&modestbranding=1&playsinline=1`;
---
<div class="youtube-facade" data-youtube-facade data-src={embedSrc} data-title={title}>
  <Picture
    src={thumbnail}
    alt="Why Business Owners Get Stuck and How to Break Through video thumbnail"
    widths={[320, 480, 640, 720, 768, 960]}
    sizes="(max-width: 720px) calc(100vw - 32px), 520px"
    formats={['avif', 'webp']}
    quality={70}
    loading="eager"
    decoding="sync"
    fetchpriority="high"
    class="youtube-facade__image"
  />
  <button type="button" class="youtube-facade__button" aria-label={title}>
    <span class="youtube-facade__play" aria-hidden="true"></span>
  </button>
  <span class="hero-clone__sound">Enable sound</span>
</div>

<script is:inline>
  (function() {
    document.addEventListener('click', function(event) {
      const button = event.target.closest('.youtube-facade__button');
      if (!button) return;

      const root = button.closest('[data-youtube-facade]');
      if (!root || root.dataset.loaded === 'true') return;
      root.dataset.loaded = 'true';

      const iframe = document.createElement('iframe');
      iframe.src = root.dataset.src;
      iframe.title = root.dataset.title || 'YouTube video';
      iframe.allow = 'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share';
      iframe.allowFullscreen = true;
      iframe.referrerPolicy = 'strict-origin-when-cross-origin';
      iframe.loading = 'eager';
      iframe.className = 'youtube-facade__iframe';

      root.replaceChildren(iframe);
      iframe.focus();
    });
  })();
</script>
