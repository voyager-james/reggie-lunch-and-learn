---
import RegisterButton from './RegisterButton.astro';

const items = [
  { title: 'The Gap', body: 'Why the business world is winning on Facebook Ads while schools aren\'t - the four real reasons.' },
  { title: 'Brand Team vs Lead Gen Team', body: 'The structural mistake nearly every school is making - and why it\'s not your team\'s fault.' },
  { title: 'The 2–3% Rule + The 3–12 Month Decision Cycle', body: 'Who your ads are actually talking to right now, and who they\'re missing.' },
  { title: 'The Capture → Nurture → Convert Method', body: 'The business-world method, stage by stage. Including the retargeting moment that changes the game.' },
  { title: 'The Other 50% - Sales Conversion', body: 'Why the phone call is half the funnel, and how to get it right without hiring a salesperson.' },
  { title: 'The Lifetime Value Reframe + Where to Start', body: 'The maths that changes the budget conversation.' },
  { title: 'Live Q&A + The Audit Offer', body: 'Free 30-minute Paid Ads Audit for the first 10 attendees who book.' },
];
---
<section class="section">
  <div class="container text-block">
    <h2 style="text-align: center;">Here's exactly what we'll cover</h2>
    <ol class="agenda">
      {items.map((item, i) => (
        <li class="agenda-row">
          <span class="agenda-pill">{i + 1}</span>
          <div>
            <div class="agenda-row-title">{item.title}</div>
            <p class="agenda-row-body">{item.body}</p>
          </div>
        </li>
      ))}
    </ol>
    <div style="text-align: center; margin-top: var(--space-xl);">
      <RegisterButton label="Register for the Webinar" />
    </div>
  </div>
</section>

<style is:global>
  .agenda {
    list-style: none;
    padding: 0;
    margin: var(--space-lg) 0 0;
    background: #fff;
    border: 1px solid var(--border-subtle);
    border-radius: var(--border-radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-sm);
  }
  .agenda-row {
    display: flex;
    align-items: flex-start;
    gap: var(--space-md);
    padding: var(--space-md) var(--space-lg);
    border-bottom: 1px solid var(--border-subtle);
  }
  .agenda-row:last-child { border-bottom: none; }
  .agenda-pill {
    flex: 0 0 28px;
    height: 28px;
    border-radius: 50%;
    background: rgba(18, 170, 235, 0.12);
    color: var(--color-primary);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 13px;
    font-weight: var(--font-weight-bold);
    margin-top: 2px;
  }
  .agenda-row-title {
    font-weight: var(--font-weight-bold);
    color: var(--color-text-dark);
    font-size: 17px;
    margin-bottom: 2px;
    line-height: 1.3;
  }
  .agenda-row-body {
    margin: 0;
    color: var(--color-text-body);
    font-size: 15px;
    line-height: 1.5;
  }

  @media (max-width: 600px) {
    .agenda-row { padding: var(--space-md); gap: var(--space-sm); }
  }
</style>
