---
import RegisterButton from './RegisterButton.astro';

const audiences = [
  {
    icon: 'briefcase',
    title: 'Marketing managers & communications coordinators',
    body: 'At private, independent, and online schools across Australia.',
  },
  {
    icon: 'building',
    title: 'Headmasters & business managers',
    body: 'At smaller private schools where leadership directly oversees marketing and enrolment growth.',
  },
  {
    icon: 'users',
    title: 'Enrolment & admissions leads',
    body: 'Anyone responsible for converting enquiries into enrolled students.',
  },
];
---
<section class="section section--muted">
  <div class="container">
    <h2 style="text-align: center; margin-bottom: var(--space-xl);">
      Who this is for
    </h2>
    <div class="who-grid">
      {audiences.map(a => (
        <div class="who-card">
          <div class="who-icon" aria-hidden="true">
            {a.icon === 'briefcase' && (
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="14" rx="2" ry="2"></rect><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"></path></svg>
            )}
            {a.icon === 'building' && (
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="2" width="16" height="20" rx="2" ry="2"></rect><path d="M9 22v-4h6v4"></path><line x1="8" y1="6" x2="8" y2="6"></line><line x1="16" y1="6" x2="16" y2="6"></line><line x1="8" y1="10" x2="8" y2="10"></line><line x1="16" y1="10" x2="16" y2="10"></line><line x1="8" y1="14" x2="8" y2="14"></line><line x1="16" y1="14" x2="16" y2="14"></line></svg>
            )}
            {a.icon === 'users' && (
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>
            )}
          </div>
          <h3 class="who-title">{a.title}</h3>
          <p class="who-body">{a.body}</p>
        </div>
      ))}
    </div>
    <div style="text-align: center; margin-top: var(--space-xl);">
      <RegisterButton label="Register for the Webinar" />
    </div>
  </div>
</section>

<style is:global>
  .who-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-lg);
  }
  .who-card {
    background: #fff;
    border-radius: var(--border-radius-lg);
    padding: var(--space-lg);
    box-shadow: var(--shadow-sm);
    border-top: 4px solid var(--color-primary);
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .who-icon {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    background: rgba(18, 170, 235, 0.12);
    color: var(--color-primary);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: var(--space-md);
  }
  .who-title {
    font-size: 18px;
    font-weight: var(--font-weight-bold);
    color: var(--color-text-dark);
    margin-bottom: var(--space-sm);
    line-height: 1.3;
  }
  .who-body {
    color: var(--color-text-body);
    font-size: 15px;
    line-height: 1.5;
    margin: 0;
  }

  @media (max-width: 900px) {
    .who-grid { grid-template-columns: 1fr; gap: var(--space-md); }
  }
</style>
