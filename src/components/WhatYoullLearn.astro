---
import RegisterButton from './RegisterButton.astro';

const cards = [
  {
    num: '01',
    title: 'How to show customised ads to each parent - every week',
    body: 'Personalised Facebook Ads that follow each interested parent on their phone, week after week, until they decide. Built around the one problem they want solved for their child.',
  },
  {
    num: '02',
    title: 'The "One Parent, One Problem" principle',
    body: 'Why speaking to the one specific problem a parent wants solved for their child is what turns a 12-month enrolment decision into a 4-month one.',
  },
  {
    num: '03',
    title: 'The full Facebook Ads funnel for enrolments',
    body: 'The 3-stage system the business world has used for over a decade, now adapted for private schools: Capture, Nurture, Convert.',
  },
];
---
<section class="section section--muted">
  <div class="container">
    <div class="text-block" style="text-align: center; margin: 0 auto var(--space-xl);">
      <h2>In 60 minutes, you'll learn:</h2>
    </div>

    <div class="learn-grid">
      {cards.map(c => (
        <article class="learn-card">
          <div class="learn-num">{c.num}</div>
          <h3 class="learn-title">{c.title}</h3>
          <p class="learn-body">{c.body}</p>
        </article>
      ))}
    </div>

    <div style="text-align: center; margin-top: var(--space-xl);">
      <RegisterButton label="Register for the Webinar" />
    </div>
  </div>
</section>

<style is:global>
  .learn-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-lg);
  }
  .learn-card {
    background: #fff;
    border-radius: var(--border-radius-lg);
    padding: var(--space-lg);
    box-shadow: var(--shadow-sm);
    border-top: 4px solid var(--color-primary);
    position: relative;
    display: flex;
    flex-direction: column;
  }
  .learn-num {
    font-size: 13px;
    font-weight: var(--font-weight-bold);
    color: var(--color-primary);
    letter-spacing: 0.12em;
    margin-bottom: var(--space-md);
  }
  .learn-title {
    font-size: 22px;
    font-weight: var(--font-weight-bold);
    color: var(--color-text-dark);
    line-height: 1.25;
    margin-bottom: var(--space-md);
  }
  .learn-body {
    color: var(--color-text-body);
    font-size: 16px;
    line-height: 1.55;
    margin: 0;
  }

  @media (max-width: 900px) {
    .learn-grid { grid-template-columns: 1fr; gap: var(--space-md); }
  }
</style>
