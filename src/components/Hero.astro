---
import { webinar } from '../config/webinar';
import RegisterButton from './RegisterButton.astro';
import Countdown from './Countdown.astro';
---
<section class="hero hero--centered">
  <div class="container">
    <div class="hero-eyebrow hero-eyebrow--lg">Free Live Webinar for Australian Private School Marketing Teams</div>
    <h1 class="h1-display">The Facebook Ads System That Fills Private School Enrolments</h1>
    <p class="hero-subhead">
      Most private schools spend money on Facebook Ads and get almost nothing back.
      In 60 minutes you'll see the exact funnel that turns ad spend into a steady pipeline
      of qualified parent enquiries - and the enrolments that follow.
    </p>

    <div class="hero-cta">
      <RegisterButton />
    </div>

    <div class="hero-datetime">
      <strong>{webinar.date}</strong>
      <span class="hero-datetime-sep">·</span>
      <strong>{webinar.timeAest}</strong>
      <span class="hero-datetime-sep">·</span>
      <span>Live on Zoom</span>
    </div>

    <Countdown />

    <p class="hero-meta">60 minutes live + 15 min Q&amp;A</p>
  </div>
</section>

<style is:global>
  .hero-highlight {
    color: var(--color-primary);
    font-weight: var(--font-weight-display);
  }
  .hero--centered { text-align: center; }
  .hero--centered .container { max-width: 900px; }
  .hero--centered h1, .hero--centered h2 { max-width: 880px; margin-left: auto; margin-right: auto; }
  .hero--centered .hero-subhead { margin-left: auto; margin-right: auto; }
  .hero--centered .hero-meta { text-align: center; }

  .hero-eyebrow--lg {
    font-size: 16px;
    letter-spacing: 0.12em;
    margin-bottom: var(--space-lg);
  }
  .hero-h2 {
    font-weight: var(--font-weight-light);
    margin-bottom: var(--space-lg);
    color: rgba(255, 255, 255, 0.92);
  }
  .hero-datetime {
    margin: var(--space-lg) auto var(--space-md);
    font-size: 22px;
    color: #fff;
    display: inline-flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: var(--space-sm);
    line-height: 1.3;
  }
  .hero-datetime strong { color: var(--color-primary); font-weight: var(--font-weight-bold); }
  .hero-datetime-sep { color: rgba(255, 255, 255, 0.35); }

  .hero-cta { margin-top: var(--space-md); }

  @media (max-width: 600px) {
    .hero-eyebrow--lg { font-size: 13px; letter-spacing: 0.1em; }
    .hero-datetime { font-size: 17px; gap: 6px; }
    .hero-datetime-sep { display: none; }
    .hero-datetime { flex-direction: column; }
  }
</style>
