---
import RegisterButton from './RegisterButton.astro';
import { Image } from 'astro:assets';
import logoImage from '../assets/images/reggie/actioncoach-logo-full.webp';

interface Props {
  showCta?: boolean;
}

const { showCta = true } = Astro.props;
---
<header class={`nav${showCta ? '' : ' nav--centered'}`}>
  <div class="nav-promo">
    <div class="nav-promo__inner">30-Day Business Owner Mastery <span aria-hidden="true">❯❯</span></div>
  </div>
  <div class="nav-inner">
    <a href="/lunch-and-learn" class="nav-brand" aria-label="ActionCOACH Lunch and Learn">
      <Image
        src={logoImage}
        alt=""
        class="nav-logo"
        widths={[66, 118, 206]}
        sizes="(max-width: 600px) 66px, 118px"
        loading="eager"
        decoding="async"
      />
    </a>
    {showCta && <RegisterButton label="Reserve Your Seat" size="sm" />}
  </div>
</header>

<style is:global>
  .nav-brand {
    gap: 0.35rem;
  }

  .nav-logo {
    display: block;
    flex: 0 0 auto;
    height: 48px;
    width: 83px;
    object-fit: contain;
  }

  .nav--centered .nav-inner {
    justify-content: center;
  }

  @media (max-width: 600px) {
    .nav-logo {
      height: 38px;
      width: 66px;
    }
  }
</style>
